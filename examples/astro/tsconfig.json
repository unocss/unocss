{
  "compilerOptions": {
    "extends": "astro/tsconfigs/strict",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true,
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"],
    "compilerOptions": {
      // Needed for TypeScript intellisense in the template inside Vue files
      "jsx": "preserve"
    }
  }
}
